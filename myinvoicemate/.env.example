GEMINI_API_KEY=your_gemini_api_key_here
VOICE_API_KEY=your_voice_to_text_api_key_here

# Vertex AI Search configuration (OAuth2)
# See backend/knowledge_assistant/VERTEX_AI_SETUP.md for setup instructions
# Generate access token: gcloud auth print-access-token
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=global
VERTEX_DATASTORE_ID=your-datastore-id
VERTEX_ACCESS_TOKEN=your-oauth2-access-token-here

# Firebase configuration (shared)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase Web
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_WEB_APP_ID=1:your-sender-id:web:your-web-app-id
FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Android
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=1:your-sender-id:android:your-android-app-id

# Firebase iOS / macOS
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=1:your-sender-id:ios:your-ios-app-id
FIREBASE_IOS_BUNDLE_ID=com.example.yourapp

# Firebase Windows
FIREBASE_WINDOWS_APP_ID=1:your-sender-id:web:your-windows-app-id
FIREBASE_WINDOWS_MEASUREMENT_ID=G-XXXXXXXXXX
